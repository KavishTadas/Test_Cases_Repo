<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="HCM Smoke Suite" verbose="1" parallel="methods" thread-count="3">

    <listeners>
        <listener class-name="com.kavish.core.listeners.TestListener"/>
        <listener class-name="com.kavish.core.listeners.GroupsListener"/>
    </listeners>

    <!-- Only @FrameworkAnnotation(category=SMOKE, service="hcm") tests -->
    <test name="HCM Smoke Tests">
        <groups>
            <run>
                <include name="SMOKE"/>
            </run>
        </groups>
        <packages>
            <package name="com.kavish.services.hcm.tests"/>
        </packages>
    </test>

</suite>
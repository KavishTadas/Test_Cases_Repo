<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CRM Regression Suite" verbose="1" parallel="methods" thread-count="3">

    <listeners>
        <listener class-name="com.kavish.core.listeners.TestListener"/>
        <listener class-name="com.kavish.core.listeners.GroupsListener"/>
    </listeners>

    <!-- Only @FrameworkAnnotation(category=REGRESSION, service="crm") tests -->
    <test name="CRM Regression Tests">
        <groups>
            <run>
                <include name="REGRESSION"/>
            </run>
        </groups>
        <packages>
            <package name="com.kavish.services.crm.tests"/>
        </packages>
    </test>

</suite>
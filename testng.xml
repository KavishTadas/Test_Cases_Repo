<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite" verbose="1" parallel="methods" thread-count="3">

    <listeners>
        <listener class-name="com.kavish.core.listeners.TestListener"/>
        <listener class-name="com.kavish.core.listeners.GroupsListener"/>
    </listeners>

    <test name="Platform Login Tests">
        <classes>
            <class name="com.kavish.services.platform.tests.LoginTest"/>
        </classes>
    </test>

</suite>
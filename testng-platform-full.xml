<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Platform Full Suite" verbose="1" parallel="methods" thread-count="3">

    <listeners>
        <listener class-name="com.kavish.core.listeners.TestListener"/>
        <listener class-name="com.kavish.core.listeners.GroupsListener"/>
    </listeners>

    <!-- Platform service — LoginTest lives here, always has tests -->
    <test name="Platform Tests">
        <packages>
            <package name="com.kavish.services.platform.tests"/>
        </packages>
    </test>

    <test name="HCM Tests">
        <packages>
            <package name="com.kavish.services.hcm.tests"/>
        </packages>
    </test>

    <test name="CRM Tests">
        <packages>
            <package name="com.kavish.services.crm.tests"/>
        </packages>
    </test>

    <test name="OKR Tests">
        <packages>
            <package name="com.kavish.services.okr.tests"/>
        </packages>
    </test>

    <test name="PM Tests">
        <packages>
            <package name="com.kavish.services.pm.tests"/>
        </packages>
    </test>

</suite>